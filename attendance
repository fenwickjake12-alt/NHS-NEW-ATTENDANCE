<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Roll Call — Meeting Attendance</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Zilla+Slab:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#EEEAE0;
    --paper-deep:#E4DFD1;
    --line:#C9C2B2;
    --ink:#23262B;
    --ink-soft:#5B584F;
    --stamp:#1F5C4B;
    --stamp-light:#E4EFE9;
    --alert:#8C3B2E;
    --alert-light:#F3E2DD;
    --gold:#8A6D2F;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:
      repeating-linear-gradient(var(--paper) 0px, var(--paper) 27px, var(--line) 28px),
      var(--paper);
    color:var(--ink);
    font-family:'IBM Plex Sans', sans-serif;
    min-height:100vh;
    padding:28px 16px 60px;
  }
  .wrap{max-width:720px;margin:0 auto;}

  header{margin-bottom:22px;}
  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:var(--ink-soft);
    display:flex;
    align-items:center;
    gap:8px;
  }
  .eyebrow::before{content:"§";color:var(--gold);font-weight:600;}
  h1{
    font-family:'Zilla Slab', serif;
    font-weight:700;
    font-size:40px;
    margin:2px 0 4px;
    letter-spacing:-.01em;
  }
  .sub{color:var(--ink-soft);font-size:14.5px;max-width:52ch;line-height:1.5;}

  nav.tabs{
    display:flex;
    gap:2px;
    margin:26px 0 0;
    border-bottom:2px solid var(--ink);
  }
  nav.tabs button{
    font-family:'IBM Plex Mono', monospace;
    font-size:12.5px;
    letter-spacing:.06em;
    text-transform:uppercase;
    background:var(--paper-deep);
    border:2px solid var(--ink);
    border-bottom:none;
    color:var(--ink-soft);
    padding:9px 16px 8px;
    border-radius:6px 6px 0 0;
    cursor:pointer;
    position:relative;
    top:2px;
  }
  nav.tabs button.active{
    background:var(--paper);
    color:var(--ink);
    font-weight:600;
    top:0;
    padding-bottom:10px;
  }

  section.panel{
    background:var(--paper);
    border:2px solid var(--ink);
    border-top:none;
    padding:26px 24px 28px;
    border-radius:0 0 8px 8px;
  }
  section.panel[hidden]{display:none;}

  label{
    display:block;
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:.08em;
    text-transform:uppercase;
    color:var(--ink-soft);
    margin:16px 0 6px;
  }
  label:first-child{margin-top:0;}
  input[type=text], input[type=password], input[type=date], input[type=number], textarea, select{
    width:100%;
    font-family:'IBM Plex Sans', sans-serif;
    font-size:15px;
    padding:10px 11px;
    border:1.5px solid var(--ink-soft);
    border-radius:5px;
    background:#fff;
    color:var(--ink);
  }
  input:focus, textarea:focus, select:focus{
    outline:3px solid #2F4B7C55;
    border-color:#2F4B7C;
  }
  textarea{min-height:110px;font-family:'IBM Plex Mono', monospace;font-size:13.5px;resize:vertical;}
  .row{display:flex;gap:12px;}
  .row > div{flex:1;}
  .hint{font-size:12px;color:var(--ink-soft);margin-top:5px;line-height:1.4;}

  .btn{
    font-family:'IBM Plex Mono', monospace;
    font-size:13px;
    letter-spacing:.05em;
    text-transform:uppercase;
    padding:11px 18px;
    border-radius:5px;
    border:2px solid var(--ink);
    background:var(--ink);
    color:var(--paper);
    cursor:pointer;
    font-weight:500;
  }
  .btn:hover{opacity:.88;}
  .btn:disabled{opacity:.45;cursor:not-allowed;}
  .btn.ghost{background:transparent;color:var(--ink);}
  .btn.small{padding:7px 12px;font-size:11px;}

  hr.rule{border:none;border-top:1.5px dashed var(--line);margin:26px 0;}

  .meeting-card{
    border:1.5px solid var(--line);
    background:#fff;
    border-radius:6px;
    padding:13px 14px;
    margin-top:10px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:10px;
  }
  .meeting-card .m-name{font-weight:600;font-family:'Zilla Slab',serif;font-size:17px;}
  .meeting-card .m-meta{font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:var(--ink-soft);margin-top:3px;}

  .status{
    margin-top:18px;
    padding:13px 14px;
    border-radius:6px;
    font-size:14px;
    line-height:1.5;
    display:none;
  }
  .status.show{display:block;}
  .status.ok{background:var(--stamp-light);color:var(--stamp);border:1.5px solid var(--stamp);}
  .status.err{background:var(--alert-light);color:var(--alert);border:1.5px solid var(--alert);}
  .status.wait{background:#EFEAD9;color:var(--ink-soft);border:1.5px solid var(--line);}

  .stamp-mark{
    display:inline-flex;
    align-items:center;
    gap:8px;
    font-family:'Zilla Slab',serif;
    font-weight:700;
    font-size:15px;
    color:var(--stamp);
    border:2.5px solid var(--stamp);
    border-radius:4px;
    padding:2px 9px;
    transform:rotate(-4deg);
    letter-spacing:.04em;
  }

  .roster-list{margin-top:14px;border-top:1.5px solid var(--line);}
  .roster-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:10px 2px;
    border-bottom:1.5px solid var(--line);
    font-size:14.5px;
  }
  .roster-row .rname{font-weight:500;}
  .roster-row .rtime{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-soft);}
  .present-stamp{
    font-family:'IBM Plex Mono',monospace;
    font-size:10.5px;
    letter-spacing:.06em;
    color:var(--stamp);
    border:1.5px solid var(--stamp);
    border-radius:3px;
    padding:2px 7px;
    transform:rotate(-3deg);
  }
  .absent-dot{
    font-family:'IBM Plex Mono',monospace;
    font-size:10.5px;
    letter-spacing:.06em;
    color:var(--ink-soft);
  }
  .tally{
    font-family:'IBM Plex Mono',monospace;
    font-size:12.5px;
    color:var(--ink-soft);
    margin-top:16px;
  }
  .empty{color:var(--ink-soft);font-size:13.5px;font-style:italic;margin-top:10px;}
  .link-btn{
    background:none;border:none;color:var(--alert);font-family:'IBM Plex Mono',monospace;
    font-size:11px;text-transform:uppercase;letter-spacing:.05em;cursor:pointer;padding:4px 6px;
  }

  /* ---- role gate ---- */
  .gate-wrap{max-width:420px;margin:60px auto;text-align:center;}
  .gate-wrap .eyebrow{justify-content:center;}
  .role-choice{
    display:flex;
    gap:14px;
    margin-top:28px;
  }
  .role-card{
    flex:1;
    background:#fff;
    border:2px solid var(--ink);
    border-radius:8px;
    padding:20px 14px;
    cursor:pointer;
    text-align:left;
  }
  .role-card:hover{background:var(--stamp-light);border-color:var(--stamp);}
  .role-card .r-title{font-family:'Zilla Slab',serif;font-weight:700;font-size:18px;margin-bottom:5px;}
  .role-card .r-desc{font-size:12.5px;color:var(--ink-soft);line-height:1.4;}
  .pin-box{
    max-width:320px;
    margin:26px auto 0;
    text-align:left;
  }
  .back-link{
    background:none;border:none;color:var(--ink-soft);font-family:'IBM Plex Mono',monospace;
    font-size:11px;text-transform:uppercase;letter-spacing:.05em;cursor:pointer;
    margin-top:16px;text-decoration:underline;
  }
  .organizer-bar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    font-family:'IBM Plex Mono',monospace;
    font-size:11px;
    letter-spacing:.05em;
    text-transform:uppercase;
    color:var(--ink-soft);
    margin-bottom:10px;
  }
  .organizer-bar .exit{
    background:none;border:none;color:var(--alert);cursor:pointer;
    font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.05em;text-transform:uppercase;
    text-decoration:underline;
  }
  [hidden]{display:none !important;}
</style>
</head>
<body>
<div class="wrap">

  <!-- ROLE GATE (default landing) -->
  <div class="gate-wrap" id="gateScreen">
    <div class="eyebrow">Roll Call — Attendance Ledger</div>
    <h1>Roll Call</h1>
    <p class="sub" style="margin:0 auto;">Who's opening this?</p>
    <div class="role-choice">
      <div class="role-card" id="pickAttendee">
        <div class="r-title">Check In</div>
        <div class="r-desc">I'm attending a meeting and need to mark myself present.</div>
      </div>
      <div class="role-card" id="pickOrganizer">
        <div class="r-title">Organizer</div>
        <div class="r-desc">I set up meetings, the roster, and the location — PIN required.</div>
      </div>
    </div>

    <div class="pin-box" id="pinBox" hidden>
      <label id="pinLabel">Organizer PIN</label>
      <input type="text" id="pinInput" placeholder="Enter PIN">
      <button class="btn" id="pinSubmit" style="margin-top:12px;">Enter</button>
      <div class="status" id="pinStatus"></div>
      <button class="back-link" id="pinBack">← back</button>
    </div>
  </div>

  <!-- ATTENDEE VIEW -->
  <div id="attendeeView" hidden>
    <header>
      <div class="eyebrow">Roll Call — Check In</div>
      <h1>Check In</h1>
      <p class="sub">Enter the meeting password and your name. Roll Call confirms you're on site before marking you present.</p>
    </header>
    <section class="panel" style="border-top:2px solid var(--ink); border-radius:8px;">
      <label>Meeting password</label>
      <input type="text" id="cPass" placeholder="Enter the password your organizer shared">
      <label>Your name</label>
      <input type="text" id="cName" list="rosterHints" placeholder="Type your name exactly as on the roster" autocomplete="off">
      <datalist id="rosterHints"></datalist>
      <button class="btn" id="doCheckin" style="margin-top:20px;">Check in</button>
      <div class="status" id="checkinStatus"></div>
      <p class="hint" style="margin-top:16px;">Check-in confirms you're within range of the meeting location and allows one submission per device.</p>
    </section>
    <button class="back-link" id="attendeeBack" style="margin-top:18px;">Organizer? Log in here</button>
  </div>

  <!-- ORGANIZER VIEW -->
  <div id="organizerView" hidden>
  <div class="organizer-bar">
    <span>Organizer mode</span>
    <button class="exit" id="exitOrganizer">Exit to check-in</button>
  </div>
  <header>
    <div class="eyebrow">Roll Call — Attendance Ledger</div>
    <h1>Roll Call</h1>
    <p class="sub">Set a meeting password and a location radius. Attendees check in from their own device — Roll Call confirms they're on site and marks them present.</p>
  </header>

  <nav class="tabs">
    <button data-tab="setup" class="active">Setup</button>
    <button data-tab="ledger">Ledger</button>
  </nav>

  <!-- SETUP -->
  <section class="panel" id="panel-setup">
    <label>Meeting name</label>
    <input type="text" id="mName" placeholder="e.g. Weekly Staff Meeting">

    <div class="row">
      <div>
        <label>Date</label>
        <input type="date" id="mDate">
      </div>
      <div>
        <label>Password for this meeting</label>
        <input type="text" id="mPass" placeholder="e.g. staff0715">
      </div>
    </div>

    <label>Roster — one name per line</label>
    <textarea id="mRoster" placeholder="Alex Rivera&#10;Jordan Lee&#10;Sam Patel"></textarea>
    <p class="hint">Names are matched case-insensitively at check-in. Someone not on this list can't check in.</p>

    <label>Meeting room location</label>
    <div class="row">
      <div>
        <input type="text" id="mLat" placeholder="Latitude">
      </div>
      <div>
        <input type="text" id="mLng" placeholder="Longitude">
      </div>
    </div>
    <button class="btn ghost small" id="useMyLoc" style="margin-top:9px;">Use my current location</button>

    <label>Check-in radius (meters)</label>
    <input type="number" id="mRadius" value="120" min="5">
    <p class="hint">120m covers most single buildings. Tighten it for a single room, loosen it for a campus.</p>

    <button class="btn" id="createMeeting" style="margin-top:20px;">Create meeting</button>
    <div class="status" id="setupStatus"></div>

    <hr class="rule">
    <label style="margin:0 0 4px;">Existing meetings</label>
    <div id="meetingList"><p class="empty">No meetings yet — create one above.</p></div>
  </section>

  <!-- LEDGER -->
  <section class="panel" id="panel-ledger" hidden>
    <label>Select meeting</label>
    <select id="ledgerSelect"><option value="">— choose a meeting —</option></select>
    <div id="ledgerBody"><p class="empty">Choose a meeting to see who's checked in.</p></div>
  </section>

  </div><!-- /organizerView -->

</div>

<script>
(function(){
  const $ = (id) => document.getElementById(id);

  // ---------- tabs (organizer view only: setup / ledger) ----------
  document.querySelectorAll('nav.tabs button').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      document.querySelectorAll('nav.tabs button').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      ['setup','ledger'].forEach(t=>{
        $('panel-'+t).hidden = (t !== btn.dataset.tab);
      });
      if(btn.dataset.tab === 'ledger') refreshMeetingSelect();
      if(btn.dataset.tab === 'setup') refreshMeetingList();
    });
  });

  // ---------- role gate ----------
  function showScreen(which){
    $('gateScreen').hidden = which !== 'gate';
    $('attendeeView').hidden = which !== 'attendee';
    $('organizerView').hidden = which !== 'organizer';
    $('pinBox').hidden = true;
  }

  async function getAdminPin(){
    try{
      const r = await window.storage.get('admin-pin', true);
      return r && r.value ? r.value : null;
    }catch(e){ return null; }
  }

  $('pickAttendee').addEventListener('click', ()=> showScreen('attendee'));
  $('attendeeBack').addEventListener('click', ()=> showScreen('gate'));
  $('exitOrganizer').addEventListener('click', ()=> showScreen('gate'));

  $('pickOrganizer').addEventListener('click', async ()=>{
    const existing = await getAdminPin();
    $('pinLabel').textContent = existing ? 'Organizer PIN' : 'Create an organizer PIN (first time setup)';
    $('pinInput').value = '';
    $('pinStatus').className = 'status';
    $('pinBox').hidden = false;
    $('pinInput').focus();
  });
  $('pinBack').addEventListener('click', ()=>{ $('pinBox').hidden = true; });

  $('pinSubmit').addEventListener('click', submitPin);
  $('pinInput').addEventListener('keydown', e=>{ if(e.key === 'Enter') submitPin(); });

  async function submitPin(){
    const entered = $('pinInput').value.trim();
    const statusEl = $('pinStatus');
    if(!entered){
      setStatus(statusEl, 'err', 'Enter a PIN.');
      return;
    }
    const existing = await getAdminPin();
    if(!existing){
      if(entered.length < 4){
        setStatus(statusEl, 'err', 'Use at least 4 characters for your PIN.');
        return;
      }
      await window.storage.set('admin-pin', entered, true);
      showScreen('organizer');
      refreshMeetingList();
      return;
    }
    if(entered === existing){
      showScreen('organizer');
      refreshMeetingList();
    }else{
      setStatus(statusEl, 'err', 'Incorrect PIN.');
    }
  }

  // ---------- helpers ----------
  function uid(){ return Math.random().toString(36).slice(2,10) + Date.now().toString(36); }

  function haversine(lat1,lon1,lat2,lon2){
    const R = 6371000;
    const toRad = d => d * Math.PI/180;
    const dLat = toRad(lat2-lat1), dLon = toRad(lon2-lon1);
    const a = Math.sin(dLat/2)**2 + Math.cos(toRad(lat1))*Math.cos(toRad(lat2))*Math.sin(dLon/2)**2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  }

  async function getDeviceId(){
    try{
      const r = await window.storage.get('device-id', false);
      if(r && r.value) return r.value;
    }catch(e){}
    const id = uid();
    try{ await window.storage.set('device-id', id, false); }catch(e){}
    return id;
  }

  async function listMeetings(){
    try{
      const r = await window.storage.get('meeting-index', true);
      return r && r.value ? JSON.parse(r.value) : [];
    }catch(e){ return []; }
  }
  async function saveMeetingIndex(ids){
    await window.storage.set('meeting-index', JSON.stringify(ids), true);
  }
  async function getMeeting(id){
    try{
      const r = await window.storage.get('meeting:'+id, true);
      return r && r.value ? JSON.parse(r.value) : null;
    }catch(e){ return null; }
  }
  async function saveMeeting(m){
    await window.storage.set('meeting:'+m.id, JSON.stringify(m), true);
  }
  async function getAttendance(id){
    try{
      const r = await window.storage.get('attendance:'+id, true);
      return r && r.value ? JSON.parse(r.value) : {};
    }catch(e){ return {}; }
  }
  async function saveAttendance(id, data){
    await window.storage.set('attendance:'+id, JSON.stringify(data), true);
  }

  function setStatus(el, kind, html){
    el.className = 'status show ' + kind;
    el.innerHTML = html;
  }

  // ---------- setup tab ----------
  $('useMyLoc').addEventListener('click', ()=>{
    if(!navigator.geolocation){ alert('Geolocation is not available in this browser.'); return; }
    $('useMyLoc').textContent = 'Locating…';
    navigator.geolocation.getCurrentPosition(pos=>{
      $('mLat').value = pos.coords.latitude.toFixed(6);
      $('mLng').value = pos.coords.longitude.toFixed(6);
      $('useMyLoc').textContent = 'Use my current location';
    }, err=>{
      $('useMyLoc').textContent = 'Use my current location';
      alert('Could not get your location: ' + err.message);
    });
  });

  $('createMeeting').addEventListener('click', async ()=>{
    const name = $('mName').value.trim();
    const date = $('mDate').value;
    const pass = $('mPass').value.trim();
    const roster = $('mRoster').value.split('\n').map(s=>s.trim()).filter(Boolean);
    const lat = parseFloat($('mLat').value);
    const lng = parseFloat($('mLng').value);
    const radius = parseFloat($('mRadius').value) || 120;
    const statusEl = $('setupStatus');

    if(!name || !date || !pass || roster.length === 0 || isNaN(lat) || isNaN(lng)){
      setStatus(statusEl, 'err', 'Fill in the meeting name, date, password, at least one roster name, and a location.');
      return;
    }

    const meeting = { id: uid(), name, date, password: pass, roster, lat, lng, radius, createdAt: Date.now() };
    $('createMeeting').disabled = true;
    await saveMeeting(meeting);
    const ids = await listMeetings();
    ids.push(meeting.id);
    await saveMeetingIndex(ids);
    await saveAttendance(meeting.id, {});
    $('createMeeting').disabled = false;

    setStatus(statusEl, 'ok', 'Meeting created. Share the password with attendees — they check in from the "Check In" tab.');
    $('mName').value=''; $('mPass').value=''; $('mRoster').value=''; $('mLat').value=''; $('mLng').value='';
    refreshMeetingList();
  });

  async function refreshMeetingList(){
    const ids = await listMeetings();
    const wrap = $('meetingList');
    if(ids.length === 0){ wrap.innerHTML = '<p class="empty">No meetings yet — create one above.</p>'; return; }
    const meetings = (await Promise.all(ids.map(getMeeting))).filter(Boolean);
    meetings.sort((a,b)=> b.createdAt - a.createdAt);
    wrap.innerHTML = '';
    for(const m of meetings){
      const att = await getAttendance(m.id);
      const count = Object.keys(att).length;
      const card = document.createElement('div');
      card.className = 'meeting-card';
      card.innerHTML = `<div>
          <div class="m-name">${escapeHtml(m.name)}</div>
          <div class="m-meta">${m.date} · ${count}/${m.roster.length} checked in · radius ${m.radius}m</div>
        </div>
        <button class="link-btn" data-del="${m.id}">Delete</button>`;
      wrap.appendChild(card);
    }
    wrap.querySelectorAll('[data-del]').forEach(b=>{
      b.addEventListener('click', async ()=>{
        if(!confirm('Delete this meeting and its attendance records?')) return;
        const id = b.dataset.del;
        const ids2 = (await listMeetings()).filter(x=>x!==id);
        await saveMeetingIndex(ids2);
        refreshMeetingList();
      });
    });
  }

  function escapeHtml(s){
    return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  // ---------- check-in tab ----------
  $('cPass').addEventListener('input', async ()=>{
    const pass = $('cPass').value.trim();
    const hints = $('rosterHints');
    hints.innerHTML = '';
    if(!pass) return;
    const ids = await listMeetings();
    const meetings = (await Promise.all(ids.map(getMeeting))).filter(Boolean);
    const match = meetings.find(m => m.password === pass);
    if(match){
      match.roster.forEach(n=>{
        const opt = document.createElement('option');
        opt.value = n;
        hints.appendChild(opt);
      });
    }
  });

  $('doCheckin').addEventListener('click', async ()=>{
    const statusEl = $('checkinStatus');
    const pass = $('cPass').value.trim();
    const nameInput = $('cName').value.trim();
    if(!pass || !nameInput){
      setStatus(statusEl, 'err', 'Enter both the meeting password and your name.');
      return;
    }

    $('doCheckin').disabled = true;
    setStatus(statusEl, 'wait', 'Checking your location…');

    const ids = await listMeetings();
    const meetings = (await Promise.all(ids.map(getMeeting))).filter(Boolean);
    const meeting = meetings.find(m => m.password === pass);
    if(!meeting){
      setStatus(statusEl, 'err', "That password doesn't match any open meeting. Double-check with your organizer.");
      $('doCheckin').disabled = false;
      return;
    }

    const rosterMatch = meeting.roster.find(n => n.toLowerCase() === nameInput.toLowerCase());
    if(!rosterMatch){
      setStatus(statusEl, 'err', "That name isn't on this meeting's roster. Check the spelling, or ask your organizer to add you.");
      $('doCheckin').disabled = false;
      return;
    }

    const attendance = await getAttendance(meeting.id);
    if(attendance[rosterMatch]){
      setStatus(statusEl, 'err', rosterMatch + ' has already been checked in for this meeting.');
      $('doCheckin').disabled = false;
      return;
    }

    const deviceId = await getDeviceId();
    const alreadyUsed = Object.values(attendance).some(a => a.deviceId === deviceId);
    if(alreadyUsed){
      setStatus(statusEl, 'err', 'This device has already submitted a check-in for this meeting.');
      $('doCheckin').disabled = false;
      return;
    }

    if(!navigator.geolocation){
      setStatus(statusEl, 'err', 'This browser does not support location — check-in requires it.');
      $('doCheckin').disabled = false;
      return;
    }

    navigator.geolocation.getCurrentPosition(async pos=>{
      const dist = haversine(pos.coords.latitude, pos.coords.longitude, meeting.lat, meeting.lng);
      if(dist > meeting.radius){
        setStatus(statusEl, 'err', `You're about ${Math.round(dist)}m from the meeting location — outside the ${meeting.radius}m check-in radius.`);
        $('doCheckin').disabled = false;
        return;
      }
      const fresh = await getAttendance(meeting.id);
      if(fresh[rosterMatch] || Object.values(fresh).some(a=>a.deviceId===deviceId)){
        setStatus(statusEl, 'err', 'This name or device has just been checked in already.');
        $('doCheckin').disabled = false;
        return;
      }
      fresh[rosterMatch] = { time: Date.now(), deviceId, distanceM: Math.round(dist) };
      await saveAttendance(meeting.id, fresh);
      setStatus(statusEl, 'ok', `<span class="stamp-mark">✓ PRESENT</span> &nbsp;${rosterMatch}, you're checked in for ${escapeHtml(meeting.name)}.`);
      $('cPass').value=''; $('cName').value='';
      $('doCheckin').disabled = false;
    }, err=>{
      setStatus(statusEl, 'err', 'Could not get your location (' + err.message + '). Location access is required to check in.');
      $('doCheckin').disabled = false;
    }, { enableHighAccuracy:true, timeout:10000 });
  });

  // ---------- ledger tab ----------
  async function refreshMeetingSelect(){
    const sel = $('ledgerSelect');
    const current = sel.value;
    const ids = await listMeetings();
    const meetings = (await Promise.all(ids.map(getMeeting))).filter(Boolean);
    meetings.sort((a,b)=> b.createdAt - a.createdAt);
    sel.innerHTML = '<option value="">— choose a meeting —</option>' +
      meetings.map(m => `<option value="${m.id}">${escapeHtml(m.name)} — ${m.date}</option>`).join('');
    if(current) sel.value = current;
  }

  $('ledgerSelect').addEventListener('change', renderLedger);

  async function renderLedger(){
    const id = $('ledgerSelect').value;
    const body = $('ledgerBody');
    if(!id){ body.innerHTML = '<p class="empty">Choose a meeting to see who\'s checked in.</p>'; return; }
    const meeting = await getMeeting(id);
    if(!meeting){ body.innerHTML = '<p class="empty">Meeting not found.</p>'; return; }
    const attendance = await getAttendance(id);
    const rows = meeting.roster.map(n=>{
      const rec = attendance[n];
      if(rec){
        const t = new Date(rec.time).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
        return `<div class="roster-row"><span class="rname">${escapeHtml(n)}</span>
          <span><span class="present-stamp">PRESENT</span> <span class="rtime">${t}</span></span></div>`;
      }
      return `<div class="roster-row"><span class="rname">${escapeHtml(n)}</span><span class="absent-dot">— not checked in</span></div>`;
    }).join('');
    const count = Object.keys(attendance).length;
    body.innerHTML = `<div class="roster-list">${rows}</div><div class="tally">${count} / ${meeting.roster.length} present · radius ${meeting.radius}m · updated ${new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit',second:'2-digit'})}</div>`;
  }

  // light polling while on the ledger tab
  setInterval(()=>{
    if(!$('panel-ledger').hidden && $('ledgerSelect').value) renderLedger();
  }, 4000);

  // init
  showScreen('gate');
})();
</script>
</body>
